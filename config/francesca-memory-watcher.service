[Unit]
Description=Francesca Memory Vault Watcher (Phase 1)
After=network.target

[Service]
Type=simple
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 /home/boss/francesca/agents/vault_watcher.py --daemon
Restart=always
RestartSec=10
WorkingDirectory=/home/boss/francesca/agents

[Install]
WantedBy=default.target
